CREATE DATABASE QuanLyTiemBanh;
GO

USE QuanLyTiemBanh;
GO

CREATE TABLE NHAN_VIEN(
	MaNV INT IDENTITY(1,1) PRIMARY KEY,
	TenNV TEXT NOT NULL,
	SoDienThoai CHAR(10) UNIQUE,
	ChucVu TEXT NOT NULL
);

CREATE TABLE KHACH_HANG(
	MaKH INT IDENTITY(1,1) PRIMARY KEY,
	TenKH TEXT NOT NULL,
	SoDienThoai CHAR(10) UNIQUE,
	NgayDangKi DATE NOT NULL DEFAULT CONVERT(DATE, GETDATE()),
	DiemHienCo INT NOT NULL,
	DiemDaDung INT NOT NULL
);

CREATE TABLE NHA_CUNG_CAP(
	MaNCC INT IDENTITY(1,1) PRIMARY KEY,
	TenNCC TEXT NOT NULL,
	SoDienThoai CHAR(10) UNIQUE,
	DiaChi TEXT NOT NULL
);

CREATE TABLE SAN_PHAM(
	MaSP INT IDENTITY(1,1) PRIMARY KEY,
	TenSP TEXT NOT NULL,
	MoTa TEXT NOT NULL,
	GiaNhap INT NOT NULL,
	GiaBan INT NOT NULL,

	CONSTRAINT CK_Gia CHECK (GiaBan > GiaNhap)
);

CREATE TABLE LO_HANG(
	MaLo INT IDENTITY(1,1) PRIMARY KEY,
	MaSP INT NOT NULL FOREIGN KEY (MaSP) REFERENCES SAN_PHAM(MaSP),
	NgayNhap DATETIME NOT NULL DEFAULT GETDATE(),
	NgayHetHan DATE NOT NULL,
	SoLuongNhap INT NOT NULL,
	DonGia INT NOT NULL,
	SoLuongTon INT NOT NULL,

	CONSTRAINT CK_SoLuong CHECK (SoLuongTon <= SoLuongNhap)
);

CREATE TABLE PHIEU_DAT_HANG(
	MaPhieu INT IDENTITY(1,1) PRIMARY KEY,
	MaNCC INT NOT NULL FOREIGN KEY (MaNCC) REFERENCES NHA_CUNG_CAP(MaNCC),
	NgayDat DATETIME NOT NULL DEFAULT GETDATE(),
	MaNVDat INT NOT NULL FOREIGN KEY (MaNVDat) REFERENCES NHAN_VIEN(MaNV),
	TrangThai BIT NOT NULL
);

CREATE TABLE CHI_TIET_PHIEU_DAT(
	MaPhieu INT NOT NULL FOREIGN KEY (MaPhieu) REFERENCES PHIEU_DAT_HANG(MaPhieu),
	MaSP INT NOT NULL FOREIGN KEY (MaSP) REFERENCES SAN_PHAM(MaSP),
	SoLuong INT NOT NULL,

	CONSTRAINT PK_CTPD PRIMARY KEY (MaPhieu, MaSP)
);

CREATE TABLE HOA_DON_NHAP_HANG(
	MaHDNH INT IDENTITY(1,1) PRIMARY KEY,
	MaNCC INT NOT NULL FOREIGN KEY (MaNCC) REFERENCES NHA_CUNG_CAP(MaNCC),
	MaLo INT NOT NULL FOREIGN KEY (MaLo) REFERENCES LO_HANG(MaLo),
	NgayNhap DATETIME NOT NULL DEFAULT GETDATE(),
	TongTien INT NOT NULL
);

CREATE TABLE HOA_DON_BAN_HANG(
	MaHDBH INT IDENTITY(1,1) PRIMARY KEY,
	MaKH INT NOT NULL FOREIGN KEY (MaKH) REFERENCES KHACH_HANG(MaKH),
	NgayBan DATETIME NOT NULL DEFAULT GETDATE(),
	MaNVBan INT NOT NULL FOREIGN KEY (MaNVBan) REFERENCES NHAN_VIEN(MaNV),
	TongTien INT NOT NULL,
	TichDiem INT NOT NULL DEFAULT 0
);

CREATE TABLE CHI_TIET_HDBH(
	MaHDBH INT NOT NULL FOREIGN KEY (MaHDBH) REFERENCES HOA_DON_BAN_HANG(MaHDBH),
	MaSP INT NOT NULL FOREIGN KEY (MaSP) REFERENCES SAN_PHAM(MaSP),
	SoLuong INT NOT NULL,
	DonGia INT NOT NULL
);
